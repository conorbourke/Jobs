# Copy to .env.local for `next dev`, and mirror into Cloudflare secrets/vars for deploys.

# --- Supabase (EU region project) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never exposed to the client

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- AI (server-side only) ---
OPENAI_API_KEY=sk-...

# --- Email (Resend). During dev use the onboarding domain. ---
RESEND_API_KEY=re_...
EMAIL_FROM="jobplatform <onboarding@resend.dev>"

# --- PDF rendering via Cloudflare Browser Rendering REST API ---
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...           # token with Browser Rendering edit permission

# --- Encryption key for (future) per-user OpenAI keys. 32 bytes, base64. ---
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=...
