{
  // Cloudflare Workers configuration for the OpenNext adapter.
  // `name` matches the connected Cloudflare Workers Builds service ("jobs").
  // The user-facing app name lives separately in src/config.ts (APP_NAME).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jobs",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // wrangler runs this build step before `deploy` / `versions upload`, so the
  // OpenNext worker (.open-next/worker.js) is generated even when the
  // Cloudflare Workers Builds dashboard has no build command configured.
  "build": {
    "command": "npx opennextjs-cloudflare build"
  },
  "observability": {
    "enabled": true
  }
  // Secrets (set with `wrangler secret put <NAME>`):
  //   SUPABASE_SERVICE_ROLE_KEY, OPENAI_API_KEY, RESEND_API_KEY,
  //   CLOUDFLARE_API_TOKEN (Browser Rendering), ENCRYPTION_KEY
  // Vars (set in dashboard or here under "vars"):
  //   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
  //   NEXT_PUBLIC_APP_URL, CLOUDFLARE_ACCOUNT_ID, EMAIL_FROM
}
